diff --git a/tests/codetether-review-signature-owner.test.sh b/tests/codetether-review-signature-owner.test.sh
new file mode 100755
--- /dev/null
+++ b/tests/codetether-review-signature-owner.test.sh
@@ -0,0 +1,23 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
+source "$repo_root/scripts/codetether-review/forgejo_signature.sh"
+tmp="$(mktemp -d)"
+trap 'rm -rf "$tmp"' EXIT
+
+FORGEJO_TOKEN=test-token
+PR_AUTHOR_LOGIN=author-agent
+REPO_FULL=owner/repo
+head_sha=0123456789abcdef0123456789abcdef01234567
+forgejo_request() {
+  local output="$5"
+  jq -n --arg sha "$head_sha" --arg signer "$mock_signer" \
+    '{sha:$sha,commit:{verification:{verified:true,signer:{username:$signer}}}}' > "$output"
+}
+
+mock_signer=attacker
+! forgejo_signature_verified "$head_sha" "$tmp/mismatch.json"
+mock_signer=author-agent
+forgejo_signature_verified "$head_sha" "$tmp/match.json"
+[[ "$AUTHOR_GIT_SIGNER" == forgejo:author-agent ]]
