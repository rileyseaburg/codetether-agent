+++ b/tests/codetether-review-author-protocol.test.sh
@@ -0,0 +1,84 @@
+#!/usr/bin/env bash
+set -euo pipefail
+repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
+source "$repo_root/scripts/codetether-review/common.sh"
+source "$repo_root/scripts/codetether-review/author_signature.sh"
+source "$repo_root/scripts/codetether-review/author_identity.sh"
+source "$repo_root/scripts/codetether-review/author_payload.sh"
+source "$repo_root/scripts/codetether-review/task_create.sh"
+source "$repo_root/scripts/codetether-review/author_delivery.sh"
+tmp="$(mktemp -d)"
+trap 'rm -rf "$tmp"' EXIT
+git init -q "$tmp/repo"
+cd "$tmp/repo"
+git config user.name Author
+git config user.email author@example.test
+FORGEJO_API_URL=https://forge.example/api/v1
+FORGEJO_TOKEN=test-token
+REPO_FULL=owner/repo
+PR_NUMBER=42
+PR_AUTHOR_LOGIN=Alice
+CODETETHER_REVIEW_TARGET_AGENT=reviewer
+HEAD_SHA=""
+identity="$(canonical_agent_identity forge.example alice default)"
+printf 'change\n' > file.txt
+git add file.txt
+git commit -q -m "$(cat <<EOF
+change
+
+CodeTether-Agent-Identity: $identity
+CodeTether-Session-ID: author-session
+CodeTether-Provenance-ID: ctprov_1234567890abcdef
+CodeTether-Forgejo-Host: forge.example
+CodeTether-Forgejo-Login: Alice
+CodeTether-Agent-Slot: default
+EOF
+)"
+HEAD_SHA="$(git rev-parse HEAD)"
+mkdir -p "$tmp/bin"
+cat > "$tmp/bin/forgejo-cli" <<'SCRIPT'
+#!/usr/bin/env bash
+jq -n --arg sha "$FORGEJO_TEST_SHA" '{sha:$sha,
+  commit:{verification:{verified:true,signer:{username:"Alice"}}}}'
+SCRIPT
+chmod +x "$tmp/bin/forgejo-cli"
+export PATH="$tmp/bin:$PATH" FORGEJO_TEST_SHA="$HEAD_SHA"
+load_author_identity "$HEAD_SHA" "$tmp/verification.json"
+[[ "$AUTHOR_PROVENANCE_VERIFIED" == true ]]
+[[ "$AUTHOR_AGENT_ID" == "$identity" ]]
+jq -n '{markdown:"Review diagnostic",blocking_findings:1}' > "$tmp/review.json"
+write_author_payload "$tmp/review.json" "$tmp/payload.json"
+jq -e --arg identity "$identity" '.metadata.protocol=="codetether.forgejo-author.v1"
+  and .metadata.target_agent_name==$identity
+  and .metadata.resume_session_id=="author-session"
+  and .metadata.forgejo_author_login=="alice"
+  and .metadata.preserve_session_workspace==true' "$tmp/payload.json" >/dev/null
+create_codetether_task() {
+  [[ "$3" == "$(author_work_key)" ]]
+  jq -e '.metadata.provenance_verified==true' "$4" >/dev/null
+  printf 'task_123\n'
+}
+CODETETHER_TOKEN=test-token
+CODETETHER_API_URL=https://codetether.example
+printf 'review\n' > "$tmp/review.md"
+route_author_followup "$tmp/review.json" "$tmp/review.md" "$tmp"
+grep -Fq 'codetether-author-conversation:v1:' "$tmp/review.md"
+grep -Fq 'CodeTether task: `task_123`' "$tmp/review.md"
+printf 'mismatch\n' >> file.txt
+git add file.txt
+git commit -q -m "$(cat <<EOF
+mismatch
+
+CodeTether-Agent-Identity: ctfake
+CodeTether-Session-ID: author-session
+CodeTether-Provenance-ID: ctprov_1234567890abcdef
+CodeTether-Forgejo-Host: forge.example
+CodeTether-Forgejo-Login: Alice
+CodeTether-Agent-Slot: default
+EOF
+)"
+HEAD_SHA="$(git rev-parse HEAD)"
+FORGEJO_TEST_SHA="$HEAD_SHA"
+load_author_identity "$HEAD_SHA" "$tmp/mismatch.json"
+[[ "$AUTHOR_PROVENANCE_VERIFIED" == false && -z "$AUTHOR_AGENT_ID" ]]
+echo "universal author protocol tests passed"
