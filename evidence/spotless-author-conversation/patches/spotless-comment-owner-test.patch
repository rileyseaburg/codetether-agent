diff --git a/tests/codetether-review-comment-owner.test.sh b/tests/codetether-review-comment-owner.test.sh
new file mode 100755
--- /dev/null
+++ b/tests/codetether-review-comment-owner.test.sh
@@ -0,0 +1,18 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
+source "$repo_root/scripts/codetether-review/comment_owner.sh"
+tmp="$(mktemp -d)"
+trap 'rm -rf "$tmp"' EXIT
+
+forgejo_request() {
+  [[ "$1" == GET ]]
+  printf '{"login":"codetether-bot"}\n' > "$5"
+}
+[[ "$(forgejo_comment_actor https://forgejo.test token "$tmp/actor.json")" == codetether-bot ]]
+
+jq -n '[{user:{login:"attacker"},body:"spoof"},
+  {user:{login:"codetether-bot"},body:"owned"}]' > "$tmp/comments.json"
+filter_owned_comments "$tmp/comments.json" codetether-bot "$tmp/owned.json"
+jq -e 'length==1 and .[0].body=="owned"' "$tmp/owned.json" >/dev/null
