--- a/scripts/codetether-review/author_delivery.sh
+++ b/scripts/codetether-review/author_delivery.sh
@@ -40,3 +40,16 @@
   printf '_Reviewer conversation routed to signed author `%s` as task `%s`._\n' \
     "$AUTHOR_AGENT_ID" "$task_id" >> "$review_file"
 }
+
+route_author_followup() {
+  local api_base="$1" token="$2" comments="$3" review_json="$4" review_file="$5" temp_dir="$6"
+  local task_id
+  task_id="$(ensure_author_followup "$comments" "$review_json" "$temp_dir")"
+  [[ -n "$task_id" ]] || return 0
+  append_author_followup_marker "$review_file" "$task_id"
+  load_pr_comments "$api_base" "$REPO_FULL" "$PR_NUMBER" "$token" \
+    "$temp_dir/comments-with-review.json"
+  upsert_review_comment "$api_base" "$REPO_FULL" "$PR_NUMBER" "$token" \
+    "$temp_dir/comments-with-review.json" "$review_marker" "$review_file" \
+    "$temp_dir/review-conversation-comment.json"
+}
