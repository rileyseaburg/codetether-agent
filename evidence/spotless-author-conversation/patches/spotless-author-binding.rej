--- scripts/codetether-review/forgejo_signature.sh
+++ scripts/codetether-review/forgejo_signature.sh
@@ -1,6 +1,7 @@
 #!/usr/bin/env bash
 
 forgejo_signature_verified() {
   local head="$1" output="$2" token="${FORGEJO_TOKEN:-}"
+  local expected_author="${PR_AUTHOR_LOGIN:-}"
   local api_base status verified signer response_sha
-  [[ -n "$output" && -n "$token" ]] || return 1
+  [[ -n "$output" && -n "$token" && -n "$expected_author" ]] || return 1
--- scripts/codetether-review/author_payload.sh
+++ scripts/codetether-review/author_payload.sh
@@ -17,4 +17,5 @@
     --arg target "$AUTHOR_AGENT_ID" --arg session "$AUTHOR_SESSION_ID" \
     --arg provenance "$AUTHOR_PROVENANCE_ID" --arg signer "$AUTHOR_GIT_SIGNER" \
     --arg context "$context_id" --arg repo "$REPO_FULL" --arg pr "$PR_NUMBER" \
-    --arg base "$BASE_SHA" --arg head "$HEAD_SHA" '
+    --arg base "$BASE_SHA" --arg head "$HEAD_SHA" \
+    --arg forgejo_author "$PR_AUTHOR_LOGIN" '
--- tests/playwright/codetether/pr-review-workflow.spec.ts
+++ tests/playwright/codetether/pr-review-workflow.spec.ts
@@ -78,4 +78,6 @@
     expect(script).toContain("git verify-commit");
     expect(script).toContain("CodeTether-Agent-Identity");
     expect(script).toContain(".commit.verification.verified");
+    expect(script).toContain(".commit.verification.signer.username");
     expect(script).toContain("context_id:$context");
+    expect(script).toContain("forgejo_author_login:$forgejo_author");
