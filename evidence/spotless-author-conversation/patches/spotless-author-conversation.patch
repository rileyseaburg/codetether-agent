+#!/usr/bin/env bash
+
+create_codetether_task() {
+  local url="$1" token="$2" payload="$3" response="$4"
+  local status task_id
+  status="$(curl -sS --connect-timeout "${CODETETHER_CONNECT_TIMEOUT_SECONDS:-15}" \
+    --max-time "${CODETETHER_HTTP_TIMEOUT_SECONDS:-60}" -o "$response" \
+    -w '%{http_code}' -X POST "$url" -H "Authorization: Bearer $token" \
+    -H 'Content-Type: application/json' --data-binary "@$payload")"
+  require_http_success "$status" "CodeTether author follow-up task create" "$response"
+  task_id="$(jq -r '.id // .task_id // empty' "$response")"
+  if [[ ! "$task_id" =~ ^[A-Za-z0-9_-]{1,128}$ ]]; then
+    echo "CodeTether author follow-up response lacked a valid task id." >&2
+    return 1
+  fi
+  printf '%s\n' "$task_id"
+}
