+#!/usr/bin/env bash
+set -euo pipefail
+
+repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
+source "$repo_root/scripts/codetether-review/common.sh"
+source "$repo_root/scripts/codetether-review/author_provenance.sh"
+source "$repo_root/scripts/codetether-review/author_payload.sh"
+source "$repo_root/scripts/codetether-review/author_delivery.sh"
+tmp="$(mktemp -d)"
+trap 'rm -rf "$tmp"' EXIT
+
+git init -q "$tmp/repo"
+cd "$tmp/repo"
+git config user.name "CodeTether Agent"
+git config user.email "author@example.test"
+printf 'unsigned\n' > file.txt
+git add file.txt
+git commit -q -m unsigned -m 'CodeTether-Agent-Identity: forged-agent' \
+  -m 'CodeTether-Provenance-ID: ctprov_1234567890abcdef'
+load_author_provenance HEAD
+[[ "$AUTHOR_PROVENANCE_VERIFIED" == false && -z "$AUTHOR_AGENT_ID" ]]
+
+ssh-keygen -q -t ed25519 -N '' -f "$tmp/signing-key"
+printf 'author@example.test %s\n' "$(cat "$tmp/signing-key.pub")" > "$tmp/allowed-signers"
+git config gpg.format ssh
+git config user.signingkey "$tmp/signing-key"
+git config gpg.ssh.allowedSignersFile "$tmp/allowed-signers"
+printf 'signed\n' >> file.txt
+git add file.txt
+git commit -q -S -m signed -m 'CodeTether-Agent-Identity: author-agent' \
+  -m 'CodeTether-Session-ID: author-session' \
+  -m 'CodeTether-Provenance-ID: ctprov_1234567890abcdef'
+HEAD_SHA="$(git rev-parse HEAD)"
+BASE_SHA="$(git rev-parse HEAD^)"
+REPO_FULL=owner/repo
+PR_NUMBER=42
+load_author_provenance "$HEAD_SHA"
+[[ "$AUTHOR_PROVENANCE_VERIFIED" == true ]]
+[[ "$AUTHOR_AGENT_ID" == author-agent ]]
+[[ "$AUTHOR_SESSION_ID" == author-session ]]
+
+jq -n '{markdown:"Review diagnostic",blocking_findings:1}' > "$tmp/review.json"
+write_author_followup_payload "$tmp/review.json" "$tmp/payload.json" \
+  "$(author_conversation_id)"
+jq -e --arg head "$HEAD_SHA" '.metadata.target_agent_name=="author-agent"
+  and .metadata.resume_session_id=="author-session"
+  and .metadata.head_sha==$head and .metadata.provenance_verified==true
+  and (.prompt|contains("BEGIN UNTRUSTED REVIEW MARKDOWN"))' \
+  "$tmp/payload.json" >/dev/null
+
+printf '[]\n' > "$tmp/comments.json"
+CODETETHER_URL=https://codetether.test/v1/agent/tasks
+CODETETHER_TOKEN=test-token
+create_codetether_task() {
+  jq -e '.metadata.target_agent_name=="author-agent"' "$3" >/dev/null
+  printf 'task-author-1\n'
+}
+task_id="$(ensure_author_followup "$tmp/comments.json" "$tmp/review.json" "$tmp")"
+[[ "$task_id" == task-author-1 ]]
+printf 'review\n' > "$tmp/review.md"
+append_author_followup_marker "$tmp/review.md" "$task_id"
+grep -F "<!-- codetether-author-followup:$HEAD_SHA:task-author-1 -->" \
+  "$tmp/review.md" >/dev/null
+jq -n --arg head "$HEAD_SHA" '[{body:("<!-- codetether-author-followup:"+$head+":task-author-1 -->")}]' \
+  > "$tmp/comments-existing.json"
+existing_author_followup_task "$tmp/comments-existing.json" | grep -Fx task-author-1
+
+echo "author conversation tests passed"