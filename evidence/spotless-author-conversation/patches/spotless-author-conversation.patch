+#!/usr/bin/env bash
+
+commit_trailer() {
+  git show -s --format=%B "$1" | git interpret-trailers --parse |
+    sed -n "s/^$2:[[:space:]]*//p" | tail -n 1
+}
+
+valid_agent_identity() {
+  [[ "$1" =~ ^[A-Za-z0-9][A-Za-z0-9._:@/-]{0,127}$ ]]
+}
+
+load_author_provenance() {
+  local head="$1" signature_fields
+  AUTHOR_AGENT_ID=""
+  AUTHOR_SESSION_ID=""
+  AUTHOR_PROVENANCE_ID=""
+  AUTHOR_GIT_SIGNER=""
+  AUTHOR_PROVENANCE_VERIFIED=false
+  git verify-commit "$head" >/dev/null 2>&1 || {
+    log "Author delivery disabled: head commit is not signature-verified."
+    return 0
+  }
+  AUTHOR_AGENT_ID="$(commit_trailer "$head" CodeTether-Agent-Identity)"
+  AUTHOR_SESSION_ID="$(commit_trailer "$head" CodeTether-Session-ID)"
+  AUTHOR_PROVENANCE_ID="$(commit_trailer "$head" CodeTether-Provenance-ID)"
+  signature_fields="$(git show -s --format='%G?;%GF;%GK' "$head")"
+  AUTHOR_GIT_SIGNER="$(cut -d ';' -f 2- <<< "$signature_fields")"
+  if ! valid_agent_identity "$AUTHOR_AGENT_ID"; then
+    log "Author delivery disabled: verified commit lacks a routable agent identity."
+    AUTHOR_AGENT_ID=""
+    return 0
+  fi
+  if [[ ! "$AUTHOR_PROVENANCE_ID" =~ ^ctprov_[A-Za-z0-9_-]{16,80}$ ]]; then
+    log "Author delivery disabled: verified commit lacks CodeTether provenance."
+    AUTHOR_AGENT_ID=""
+    return 0
+  fi
+  if [[ -n "$AUTHOR_SESSION_ID" && ! "$AUTHOR_SESSION_ID" =~ ^[A-Za-z0-9_-]{1,128}$ ]]; then
+    log "Ignoring unsafe author session identity from commit provenance."
+    AUTHOR_SESSION_ID=""
+  fi
+  AUTHOR_PROVENANCE_VERIFIED=true
+  log "Verified routable CodeTether author identity for ${head:0:12}."
+}
