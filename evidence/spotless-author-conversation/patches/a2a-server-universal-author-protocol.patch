diff --git a/tests/test_forgejo_author_protocol.py b/tests/test_forgejo_author_protocol.py
new file mode 100644
--- /dev/null
+++ b/tests/test_forgejo_author_protocol.py
@@ -0,0 +1,54 @@
+import pytest
+
+from a2a_server.forgejo_author_identity import canonical_identity, validate
+from a2a_server.forgejo_author_task import task_identity
+
+
+def metadata():
+    target = canonical_identity('forge.example', 'alice', 'default')
+    return {
+        'protocol': 'codetether.forgejo-author.v1',
+        'source': 'forgejo-pr-review',
+        'workflow_stage': 'forgejo-author-review',
+        'forgejo_host': 'forge.example',
+        'forgejo_author_login': 'alice',
+        'agent_slot': 'default',
+        'target_agent_name': target,
+        'repo': 'owner/repo',
+        'pr_number': 42,
+        'pr_head_sha': 'a' * 40,
+        'resume_session_id': 'author-session',
+        'author_provenance_id': 'ctprov_1234567890abcdef',
+        'provenance_verified': True,
+        'preserve_session_workspace': True,
+    }
+
+
+def test_identity_is_principal_bound():
+    value = metadata()
+    assert validate(value) == value['target_agent_name']
+    value['target_agent_name'] = canonical_identity('forge.example', 'mallory', 'default')
+    with pytest.raises(ValueError, match='target'):
+        validate(value)
+
+
+def test_task_id_is_deterministic_across_callers():
+    first = task_identity(metadata())
+    second = task_identity(dict(metadata()))
+    assert first == second
+    assert first[1].startswith('cttask_')
+
+
+def test_new_head_creates_new_logical_task():
+    first = metadata()
+    second = metadata()
+    second['pr_head_sha'] = 'b' * 40
+    assert task_identity(first) != task_identity(second)
+
+
+@pytest.mark.parametrize('field', ['resume_session_id', 'author_provenance_id'])
+def test_required_signed_continuity_fields_fail_closed(field):
+    value = metadata()
+    value[field] = ''
+    with pytest.raises(ValueError):
+        validate(value)
