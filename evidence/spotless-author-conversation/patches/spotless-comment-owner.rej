--- scripts/codetether-review/author_delivery.sh
+++ scripts/codetether-review/author_delivery.sh
@@ -42,4 +42,4 @@
 }
 
 route_author_followup() {
-  local api_base="$1" token="$2" comments="$3" review_json="$4" review_file="$5" temp_dir="$6"
+  local api_base="$1" token="$2" comments="$3" review_json="$4" review_file="$5" temp_dir="$6" actor="$7"
@@ -49,5 +49,7 @@
   append_author_followup_marker "$review_file" "$task_id"
   load_pr_comments "$api_base" "$REPO_FULL" "$PR_NUMBER" "$token" \
     "$temp_dir/comments-with-review.json"
+  filter_owned_comments "$temp_dir/comments-with-review.json" "$actor" \
+    "$temp_dir/owned-comments-with-review.json"
   upsert_review_comment "$api_base" "$REPO_FULL" "$PR_NUMBER" "$token" \
-    "$temp_dir/comments-with-review.json" "$review_marker" "$review_file" \
+    "$temp_dir/owned-comments-with-review.json" "$review_marker" "$review_file" \
--- tests/codetether-review-author-conversation.test.sh
+++ tests/codetether-review-author-conversation.test.sh
@@ -84,3 +85,8 @@
 jq -n --arg head "$HEAD_SHA" '[{body:("<!-- codetether-author-followup:"+$head+":task-author-1 -->")}]' \
   > "$tmp/comments-existing.json"
 existing_author_followup_task "$tmp/comments-existing.json" | grep -Fx task-author-1
+jq -n '[{user:{login:"attacker"},body:"spoof"},
+  {user:{login:"codetether-bot"},body:"owned"}]' > "$tmp/comment-owners.json"
+filter_owned_comments "$tmp/comment-owners.json" codetether-bot \
+  "$tmp/owned-comments.json"
+jq -e 'length==1 and .[0].body=="owned"' "$tmp/owned-comments.json" >/dev/null
