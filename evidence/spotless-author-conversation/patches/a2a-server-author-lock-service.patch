+"""Atomic creation service for verified Forgejo author conversations."""
+
+from typing import Any, Awaitable, Callable, Dict
+
+from .forgejo_author_lock import serialized
+from .forgejo_author_task import prepare
+
+WorkerValidator = Callable[..., Awaitable[None]]
+
+
+async def create(
+    bridge: Any,
+    task_data: Any,
+    metadata: Dict[str, Any],
+    routing_decision: Any,
+    workspace_id: str,
+    validate_worker: WorkerValidator,
+):
+    """Create or replay exactly one durable task for an immutable PR head."""
+    async with serialized(metadata):
+        task_id, existing = await prepare(metadata)
+        if existing:
+            return existing
+        await validate_worker(metadata, strict=True)
+        task = await bridge.create_task(
+            codebase_id=workspace_id,
+            title=task_data.title,
+            prompt=task_data.prompt,
+            agent_type=task_data.agent_type,
+            priority=task_data.priority,
+            model=metadata.get('model'),
+            metadata=metadata,
+            model_ref=routing_decision.model_ref,
+            task_id=task_id,
+            require_persistence=True,
+        )
+        if not task:
+            raise RuntimeError(
+                'verified author task could not be durably persisted'
+            )
+        return task
