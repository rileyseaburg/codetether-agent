//! GLM-5.2 direct call via Z.AI coding plan endpoint.
//!
//! Retries in a do-while loop until the API returns 200.
//! Usage: hook "call" with args [api_key, prompt].

fn call(api_key, prompt) {
    let url = "https://api.z.ai/api/coding/paas/v4/chat/completions"
    let max_tries = 200
    let sleep_ms = 5000
    let mut attempt = 0

    while attempt < max_tries {
        attempt = attempt + 1

        let body_map = map()
        body_map["model"] = "glm-5.2"

        let msg = map()
        msg["role"] = "user"
        msg["content"] = prompt

        body_map["messages"] = [msg]
        body_map["max_tokens"] = 2048
        body_map["temperature"] = 0.7

        let body = json_encode(body_map)

        let headers = map()
        headers["Authorization"] = "Bearer " + api_key
        headers["Content-Type"] = "application/json"

        let result = http_request("POST", url, body, headers)
        let resp = result?

        if resp["ok"] == true {
            let parsed = json_parse(resp["body"])
            return Ok(parsed)
        }

        // Log the failure and retry
        print("[" + str(attempt) + "] HTTP " + str(resp["status"]) + " — retrying...")
        sleep_ms(sleep_ms)
    }

    let exhausted = map()
    exhausted["error"] = "max_tries_exceeded"
    exhausted["attempts"] = max_tries
    return Ok(exhausted)
}