<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ title }}</title>
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='14' fill='%236fffe0'/%3E%3C/svg%3E">
  <style>{{ styles | safe }}</style>
</head>
<body>
  <header class="topbar">
    <a class="brand" href="/"><svg viewBox="0 0 40 40" aria-hidden="true"><path d="M7 20h7l3-9 6 18 4-9h6"/><circle cx="20" cy="20" r="17"/></svg><span>TRACE//LENS</span></a>
    <div class="source"><span class="pulse"></span><span id="source-name">{{ trace_name }}</span></div>
    <label class="upload">Open trace<input id="file-input" type="file" accept=".jsonl"></label>
  </header>
  <main>
    <section class="hero">
      <div><p class="eyebrow">NETWORK FORENSICS / LOSSLESS VIEW</p><h1>See every syscall.<br><em>Keep every byte.</em></h1></div>
      <p class="lede">A human layer over raw strace evidence. Filter the stream, inspect lexical tokens, and verify the original capture without changing it.</p>
    </section>
    <section id="metrics" class="metrics" aria-label="Trace summary"></section>
    <section class="visuals">
      <article class="panel wide"><header><div><span class="kicker">ACTIVITY</span><h2>Network timeline</h2></div><span id="timeline-label" class="tag">loading</span></header><svg id="timeline" viewBox="0 0 900 240" role="img"></svg></article>
      <article class="panel"><header><div><span class="kicker">MIX</span><h2>Syscall profile</h2></div></header><div class="donut-wrap"><svg id="donut" viewBox="0 0 220 220" role="img"></svg><ol id="legend"></ol></div></article>
      <article class="panel"><header><div><span class="kicker">ROUTE</span><h2>Connection flow</h2></div></header><svg id="flow" viewBox="0 0 520 220" role="img"></svg></article>
    </section>
    <section class="panel records"><header><div><span class="kicker">EVIDENCE</span><h2>Lossless records</h2></div><span id="visible-count" class="tag"></span></header><div class="filters"><input id="search" type="search" placeholder="Search raw syscall data"><select id="syscall"><option value="">All syscalls</option></select></div><div class="table-wrap"><table><thead><tr><th>#</th><th>Time</th><th>Call</th><th>Result</th><th>Duration</th></tr></thead><tbody id="records"></tbody></table></div></section>
  </main>
  <aside id="detail" class="drawer" aria-hidden="true"><button id="close-detail" aria-label="Close">×</button><div id="detail-body"></div></aside>
  <div id="loading" class="loading"><svg viewBox="0 0 50 50"><circle cx="25" cy="25" r="20"/></svg><span>Parsing trace…</span></div>
  <script>{{ script | safe }}</script>
</body>
</html>
